# Comma-separated list of origins allowed by CORS (frontend dev server, prod URL, ...).
ALLOWED_ORIGINS=http://localhost:5173

# Maximum accepted upload size in bytes (default 10 MB).
MAX_FILE_SIZE=10485760

# Reject images whose width or height exceeds this (px) before any resize.
MAX_DIMENSION=6000

# Longest side (px) the image is downscaled to before colour analysis.
PROCESS_MAX_SIDE=512

# Rate limit applied to the extract endpoints (slowapi syntax, e.g. "60/minute").
RATE_LIMIT=60/minute
